<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logga in — vCard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="auth-page">
  <div class="auth-box">
    <a href="/" class="nav-logo" style="display:flex; justify-content:center; margin-bottom:24px; font-size:20px;">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg" style="margin-right:8px">
        <rect x="1" y="4" width="20" height="14" rx="3" stroke="currentColor" stroke-width="1.8"/>
        <circle cx="7.5" cy="10" r="2.2" stroke="currentColor" stroke-width="1.6"/>
        <line x1="12" y1="8.5" x2="18" y2="8.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        <line x1="12" y1="11.5" x2="16" y2="11.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      vCard
    </a>
    <h1>Logga in</h1>
    <% if (error) { %>
      <p class="error"><%= error %></p>
    <% } %>
    <form method="POST" action="/auth/login">
      <label>E-post</label>
      <input type="email" name="email" required autofocus>
      <label>Lösenord</label>
      <input type="password" name="password" required>
      <button type="submit" class="btn btn-primary btn-full">Logga in</button>
    </form>
  </div>
</body>
</html>
