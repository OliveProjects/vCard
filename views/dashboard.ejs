<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Min profil — vCard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">vCard</a>
    <div class="nav-links">
      <% if (profile) { %><a href="/<%= profile.slug %>" target="_blank">Visa min sida →</a><% } %>
      <a href="/auth/logout">Logga ut</a>
    </div>
  </nav>
  <main class="dashboard">
    <h1>Min profil</h1>
    <% if (saved) { %><p class="success">Sparat!</p><% } %>

    <form method="POST" action="/dashboard/save" class="profile-form" enctype="multipart/form-data">

      <div class="form-row">
        <div class="form-group">
          <label>Namn *</label>
          <input type="text" name="name" value="<%= profile?.name || '' %>" required>
        </div>
        <div class="form-group">
          <label>Titel</label>
          <input type="text" name="title" value="<%= profile?.title || '' %>">
        </div>
      </div>

      <div class="form-group">
        <label>Företag</label>
        <input type="text" name="company" value="<%= profile?.company || '' %>">
      </div>

      <div class="form-row">
        <div class="form-group">
          <label>Telefon</label>
          <input type="tel" name="phone" value="<%= profile?.phone || '' %>">
        </div>
        <div class="form-group">
          <label>E-post (på kortet)</label>
          <input type="email" name="email" value="<%= profile?.email || '' %>">
        </div>
      </div>

      <div class="form-group">
        <label>Webbplats</label>
        <input type="url" name="website" placeholder="https://" value="<%= profile?.website || '' %>">
      </div>

      <div class="form-group">
        <label>LinkedIn-URL</label>
        <input type="url" name="linkedin" placeholder="https://linkedin.com/in/..." value="<%= profile?.linkedin || '' %>">
      </div>

      <div class="form-group">
        <label>Foto</label>
        <div class="drop-zone" id="dropZone">
          <div class="drop-zone-content" id="dropContent">
            <% if (profile?.photo_url) { %>
              <img src="<%= profile.photo_url %>" alt="Nuvarande foto" class="drop-preview" id="preview">
              <span class="drop-label" id="dropLabel">Dra en ny bild hit eller klicka för att byta</span>
            <% } else { %>
              <div class="drop-icon" id="dropIcon">📷</div>
              <span class="drop-label" id="dropLabel">Dra bilden hit eller klicka för att välja</span>
            <% } %>
          </div>
          <input type="file" name="photo" id="photoInput" accept="image/jpeg,image/png,image/webp" class="drop-input">
        </div>
        <small id="photoError" class="error-text" style="display:none;"></small>
        <small>JPG, PNG eller WebP · Max 5 MB</small>
      </div>

      <% if (profile) { %>
        <div class="form-group">
          <label>Din kortlänk</label>
          <div class="slug-display">/<%= profile.slug %></div>
          <small>NFC-chippet ska programmeras med: <%= process.env.BASE_URL || 'http://localhost:3000' %>/<%= profile.slug %></small>
        </div>
      <% } %>

      <button type="submit" class="btn btn-primary">Spara ändringar</button>
    </form>
  </main>
  <script>
    const zone      = document.getElementById('dropZone')
    const input     = document.getElementById('photoInput')
    const preview   = document.getElementById('preview')
    const dropIcon  = document.getElementById('dropIcon')
    const dropLabel = document.getElementById('dropLabel')
    const errorEl   = document.getElementById('photoError')

    const ALLOWED = ['image/jpeg', 'image/png', 'image/webp']
    const MAX_MB  = 5

    function showPreview(file) {
      errorEl.style.display = 'none'

      if (!ALLOWED.includes(file.type)) {
        errorEl.textContent = 'Ogiltigt format — använd JPG, PNG eller WebP.'
        errorEl.style.display = 'block'
        input.value = ''
        return
      }
      if (file.size > MAX_MB * 1024 * 1024) {
        errorEl.textContent = `Bilden är för stor (max ${MAX_MB} MB).`
        errorEl.style.display = 'block'
        input.value = ''
        return
      }

      const reader = new FileReader()
      reader.onload = e => {
        // Show or update preview image
        let img = document.getElementById('preview')
        if (!img) {
          img = document.createElement('img')
          img.id = 'preview'
          img.className = 'drop-preview'
          if (dropIcon) dropIcon.remove()
          zone.querySelector('.drop-zone-content').prepend(img)
        }
        img.src = e.target.result
        dropLabel.textContent = file.name
      }
      reader.readAsDataURL(file)
    }

    zone.addEventListener('click', () => input.click())

    input.addEventListener('change', () => {
      if (input.files[0]) showPreview(input.files[0])
    })

    zone.addEventListener('dragover', e => {
      e.preventDefault()
      zone.classList.add('drag-over')
    })

    zone.addEventListener('dragleave', () => zone.classList.remove('drag-over'))

    zone.addEventListener('drop', e => {
      e.preventDefault()
      zone.classList.remove('drag-over')
      const file = e.dataTransfer.files[0]
      if (!file) return
      // Transfer file to the hidden input
      const dt = new DataTransfer()
      dt.items.add(file)
      input.files = dt.files
      showPreview(file)
    })
  </script>
</body>
</html>
