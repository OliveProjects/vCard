<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title + ' — vCard' : 'vCard Hosting' %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">vCard</a>
    <div class="nav-links">
      <% if (user) { %>
        <a href="/dashboard">Min profil</a>
        <% if (user.is_admin) { %><a href="/admin">Admin</a><% } %>
        <a href="/auth/logout">Logga ut</a>
      <% } else { %>
        <a href="/auth/login">Logga in</a>
      <% } %>
    </div>
  </nav>
  <main>
    <%- body %>
  </main>
</body>
</html>
