<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= profile.name %></title>
  <link rel="stylesheet" href="/style.css">
</head>
<body class="profile-page">
  <div class="profile-card">

    <% if (profile.photo_url) { %>
      <img class="profile-photo" src="<%= profile.photo_url %>" alt="<%= profile.name %>">
    <% } else { %>
      <div class="profile-photo-placeholder"><%= profile.name ? profile.name[0].toUpperCase() : '?' %></div>
    <% } %>

    <h1 class="profile-name"><%= profile.name || '' %></h1>

    <% if (profile.title || profile.company) { %>
      <p class="profile-sub">
        <%= profile.title || '' %><% if (profile.title && profile.company) { %> · <% } %><%= profile.company || '' %>
      </p>
    <% } %>

    <div class="profile-actions">
      <a href="/<%= profile.slug %>/vcard.vcf" class="btn btn-primary">Spara kontakt</a>
    </div>

    <div class="profile-links">
      <% if (profile.phone) { %>
        <a href="tel:<%= profile.phone %>" class="profile-link">
          <span class="link-icon">📞</span><span><%= profile.phone %></span>
        </a>
      <% } %>
      <% if (profile.email) { %>
        <a href="mailto:<%= profile.email %>" class="profile-link">
          <span class="link-icon">✉️</span><span><%= profile.email %></span>
        </a>
      <% } %>
      <% if (profile.website) { %>
        <a href="<%= profile.website %>" target="_blank" class="profile-link">
          <span class="link-icon">🌐</span><span><%= profile.website.replace(/^https?:\/\//, '') %></span>
        </a>
      <% } %>
      <% if (profile.linkedin) { %>
        <a href="<%= profile.linkedin %>" target="_blank" class="profile-link">
          <span class="link-icon">💼</span><span>LinkedIn</span>
        </a>
      <% } %>
      <% if (profile.instagram) { %>
        <a href="<%= profile.instagram %>" target="_blank" class="profile-link">
          <span class="link-icon">📸</span><span>Instagram</span>
        </a>
      <% } %>
      <% if (profile.twitter) { %>
        <a href="<%= profile.twitter %>" target="_blank" class="profile-link">
          <span class="link-icon">𝕏</span><span>X (Twitter)</span>
        </a>
      <% } %>
      <% if (profile.tiktok) { %>
        <a href="<%= profile.tiktok %>" target="_blank" class="profile-link">
          <span class="link-icon">🎵</span><span>TikTok</span>
        </a>
      <% } %>
    </div>


    <div class="profile-brand">
      <a href="/" class="profile-brand-link">
        <svg width="14" height="14" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
          <rect x="1" y="4" width="20" height="14" rx="3" stroke="currentColor" stroke-width="1.8"/>
          <circle cx="7.5" cy="10" r="2.2" stroke="currentColor" stroke-width="1.6"/>
          <line x1="12" y1="8.5" x2="18" y2="8.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
          <line x1="12" y1="11.5" x2="16" y2="11.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        </svg>
        Skapat med vCard
      </a>
    </div>

  </div>
</body>
</html>
