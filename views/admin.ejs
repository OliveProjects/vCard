<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin — vCard</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>
  <nav>
    <a href="/" class="nav-logo">
      <svg width="20" height="20" viewBox="0 0 22 22" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect x="1" y="4" width="20" height="14" rx="3" stroke="currentColor" stroke-width="1.8"/>
        <circle cx="7.5" cy="10" r="2.2" stroke="currentColor" stroke-width="1.6"/>
        <line x1="12" y1="8.5" x2="18" y2="8.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
        <line x1="12" y1="11.5" x2="16" y2="11.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/>
      </svg>
      vCard
    </a>
    <div class="nav-links">
      <a href="/dashboard">Min profil</a>
      <a href="/auth/logout">Logga ut</a>
    </div>
  </nav>
  <main class="admin">
    <h1>Admin</h1>
    <% if (created) { %><p class="success">Kund skapad!</p><% } %>
    <% if (locals.reset) { %>
      <div class="success">
        Nytt tillfälligt lösenord: <strong><%= locals.reset %></strong> — skicka detta till kunden.
      </div>
    <% } %>

    <section class="admin-section">
      <h2>Skapa ny kund</h2>
      <form method="POST" action="/admin/create" class="profile-form">
        <div class="form-row">
          <div class="form-group">
            <label>Namn</label>
            <input type="text" name="name" required>
          </div>
          <div class="form-group">
            <label>Slug (URL)</label>
            <input type="text" name="slug" placeholder="t.ex. kristoffer" pattern="[a-z0-9\-]+" required>
            <small>Bara gemener, siffror och bindestreck</small>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label>E-post (inloggning)</label>
            <input type="email" name="email" required>
          </div>
          <div class="form-group">
            <label>Tillfälligt lösenord</label>
            <input type="text" name="password" required>
          </div>
        </div>
        <button type="submit" class="btn btn-primary">Skapa kund</button>
      </form>
    </section>

    <section class="admin-section">
      <h2>Alla kunder (<%= customers.length %>)</h2>
      <table class="admin-table">
        <thead>
          <tr>
            <th>Namn</th>
            <th>E-post</th>
            <th>Slug</th>
            <th>Status</th>
            <th>Skapad</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% customers.forEach(c => { %>
            <tr>
              <td><%= c.name || '—' %></td>
              <td><%= c.email %></td>
              <td><% if (c.slug) { %><a href="/<%= c.slug %>" target="_blank">/<%= c.slug %></a><% } else { %>—<% } %></td>
              <td><span class="status-badge <%= c.active ? 'active' : 'inactive' %>"><%= c.active ? 'Aktiv' : 'Inaktiv' %></span></td>
              <td><%= new Date(c.created_at).toLocaleDateString('sv-SE') %></td>
              <td class="admin-actions">
                <form method="POST" action="/admin/toggle/<%= c.id %>" style="display:inline;">
                  <button type="submit" class="btn btn-small"><%= c.active ? 'Inaktivera' : 'Aktivera' %></button>
                </form>
                <form method="POST" action="/admin/reset-password/<%= c.id %>" style="display:inline;">
                  <button type="submit" class="btn btn-small">Återställ lösenord</button>
                </form>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </section>
  </main>
</body>
</html>
